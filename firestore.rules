rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════

    /// Whether the requester is authenticated (signed in)
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Whether the requester owns the document keyed by userId
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /// Whether the requester's UID is present in a participants array
    function isParticipant(participants) {
      return isAuthenticated() && request.auth.uid in participants;
    }

    /// Whether the requester has admin privileges.
    /// Production: use custom claim  request.auth.token.admin == true
    /// Fallback:    whitelist specific UIDs below
    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.admin == true
          || request.auth.uid in [
            // ── Add admin UIDs here ──────────────────────────────────
          ]);
    }

    /// Whether the requester's UID matches a field in the existing resource
    function isFieldOwner(field) {
      return isAuthenticated() && request.auth.uid == resource.data[field];
    }

    /// Whether a string is present and non-empty
    function isNonEmptyString(field) {
      return field is string && field.size() > 0;
    }

    /// Whether a value is a non-negative integer
    function isNonNegative(value) {
      return value is int && value >= 0;
    }

    /// Whether the update only modifies the likes and likedBy fields
    function onlyUpdatingLikes() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['likes', 'likedBy']);
    }

    /// Whether the update only modifies the read status field
    function onlyUpdatingReadStatus() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['read']);
    }

    /// Resolve the participants array of a chat document (used by messages)
    function chatParticipants(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // ═══════════════════════════════════════════════════════════════════
    //  users/{userId}  — Private user data
    //  Access: owner read / owner write
    // ═══════════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read:   if isOwner(userId);
      // CREATE is permissive to allow the initial sparse document during signup
      // (before onboarding is complete). The document may lack quitDate/quitType.
      allow create: if isOwner(userId)
                     && isNonEmptyString(request.resource.data.email)
                     && request.resource.data.createdAt is timestamp;
      // UPDATE requires the full set of fields after onboarding is complete.
      // This ensures that once the user profile is set up, it stays valid.
      allow update: if isOwner(userId)
                     && request.resource.data.email is string
                     && isNonEmptyString(request.resource.data.nickname)
                     && request.resource.data.quitDate is timestamp
                     && request.resource.data.createdAt is timestamp;
      allow delete: if false;   // Deletion only via Cloud Functions / admin SDK
    }

    // ═══════════════════════════════════════════════════════════════════
    //  publicProfiles/{userId}  — Public profile data
    //  Access: authenticated read; owner write
    // ═══════════════════════════════════════════════════════════════════

    match /publicProfiles/{userId} {
      allow read:   if isAuthenticated();
      // CREATE is permissive to allow the initial sparse profile during signup
      // (before onboarding). The document may lack quitDate.
      allow create: if isOwner(userId)
                     && isNonEmptyString(request.resource.data.nickname)
                     && isNonNegative(request.resource.data.xp);
      allow update: if isOwner(userId)
                     && isNonEmptyString(request.resource.data.nickname)
                     && isNonNegative(request.resource.data.daysSmokeFree)
                     && isNonNegative(request.resource.data.xp);
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════
    //  stories/{storyId}  — Community stories
    //  Access: authenticated read; authenticated create; owner
    //          update/delete; anyone authenticated can update likes
    // ═══════════════════════════════════════════════════════════════════

    match /stories/{storyId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                     && request.auth.uid == request.resource.data.userId
                     && isNonEmptyString(request.resource.data.content)
                     && request.resource.data.content.size() <= 2000
                     && isNonNegative(request.resource.data.likes)
                     && request.resource.data.likedBy is list
                     && isNonNegative(request.resource.data.daysSmokeFree)
                     && isNonEmptyString(request.resource.data.nickname)
                     && request.resource.data.createdAt is timestamp;

      // Owner can update story content (must keep own userId)
      allow update: if isFieldOwner("userId")
                     && request.resource.data.userId == resource.data.userId
                     && isNonEmptyString(request.resource.data.content)
                     && request.resource.data.content.size() <= 2000
                     && isNonNegative(request.resource.data.likes)
                     && request.resource.data.likedBy is list
                     && request.resource.data.createdAt == resource.data.createdAt;

      // Any authenticated user can toggle likes (likes + likedBy only)
      allow update: if isAuthenticated()
                     && onlyUpdatingLikes()
                     && isNonNegative(request.resource.data.likes)
                     && request.resource.data.likedBy is list;

      allow delete: if isFieldOwner("userId");

      // ── replies sub-collection ────────────────────────────────────
      match /replies/{replyId} {
        allow read:   if isAuthenticated();
        allow create: if isAuthenticated()
                       && request.auth.uid == request.resource.data.userId
                       && isNonEmptyString(request.resource.data.content)
                       && request.resource.data.content.size() <= 500
                       && request.resource.data.createdAt is timestamp;
        allow update: if isFieldOwner("userId")
                       && request.resource.data.userId == resource.data.userId
                       && isNonEmptyString(request.resource.data.content)
                       && request.resource.data.content.size() <= 500;
        allow delete: if isFieldOwner("userId");
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  friendRequests/{requestId}  — Friend requests
    //  Access: involved users read; fromUser creates; toUser updates status
    // ═══════════════════════════════════════════════════════════════════

    match /friendRequests/{requestId} {
      allow read:   if isAuthenticated()
                     && (request.auth.uid == resource.data.fromUserId
                         || request.auth.uid == resource.data.toUserId);
      allow create: if isAuthenticated()
                     && request.auth.uid == request.resource.data.fromUserId
                     && request.resource.data.fromUserId != request.resource.data.toUserId
                     && isNonEmptyString(request.resource.data.fromUserId)
                     && isNonEmptyString(request.resource.data.toUserId)
                     && request.resource.data.status is string
                     && request.resource.data.timestamp is timestamp;
      allow update: if isAuthenticated()
                     && request.auth.uid == resource.data.toUserId
                     && request.resource.data.fromUserId == resource.data.fromUserId
                     && request.resource.data.toUserId == resource.data.toUserId
                     && (request.resource.data.status == "accepted"
                         || request.resource.data.status == "rejected");
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════
    //  friendships/{friendshipId}  — Established friendships
    //  Access: involved users read; authenticated create
    // ═══════════════════════════════════════════════════════════════════

    match /friendships/{friendshipId} {
      allow read:   if isAuthenticated()
                     && request.auth.uid in resource.data.userIds;
      allow create: if isAuthenticated()
                     && request.auth.uid in request.resource.data.userIds
                     && request.resource.data.userIds is list
                     && request.resource.data.userIds.size() == 2
                     && request.resource.data.createdAt is timestamp;
      allow update: if false;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════
    //  chats/{chatId}  — 1:1 chat rooms (deterministic IDs)
    //  Access: participants read/write
    // ═══════════════════════════════════════════════════════════════════

    match /chats/{chatId} {
      allow read:   if isParticipant(resource.data.participants);
      allow create: if isAuthenticated()
                     && request.resource.data.participants is list
                     && request.resource.data.participants.size() == 2
                     && request.auth.uid in request.resource.data.participants;
      allow update: if isParticipant(resource.data.participants)
                     && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      // ── messages sub-collection ───────────────────────────────────
      match /messages/{messageId} {
        allow read:   if isAuthenticated()
                       && isParticipant(chatParticipants(chatId));
        allow create: if isAuthenticated()
                       && isParticipant(chatParticipants(chatId))
                       && request.auth.uid == request.resource.data.senderId
                       && isNonEmptyString(request.resource.data.text)
                       && request.resource.data.text.size() <= 2000
                       && request.resource.data.timestamp is timestamp
                       && request.resource.data.read is bool;
        // Any participant can update the read status of a message
        allow update: if isAuthenticated()
                       && isParticipant(chatParticipants(chatId))
                       && onlyUpdatingReadStatus();
        allow delete: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  events/{eventId}  — Community events / challenges
    //  Access: authenticated read; admin write
    // ═══════════════════════════════════════════════════════════════════

    match /events/{eventId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  eventParticipants/{participantId}  — Event participation tracking
    //  Access: authenticated read; owner create/update
    // ═══════════════════════════════════════════════════════════════════

    match /eventParticipants/{participantId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                     && request.auth.uid == request.resource.data.userId
                     && isNonEmptyString(request.resource.data.eventId)
                     && isNonEmptyString(request.resource.data.userId)
                     && request.resource.data.joinedAt is timestamp;
      allow update: if isAuthenticated()
                     && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  eventCheckins/{checkinId}  — Event check-in submissions
    //  Access: authenticated read; owner create; admin update status
    // ═══════════════════════════════════════════════════════════════════

    match /eventCheckins/{checkinId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                     && request.auth.uid == request.resource.data.userId
                     && isNonEmptyString(request.resource.data.eventId)
                     && isNonEmptyString(request.resource.data.userId)
                     && isNonNegative(request.resource.data.dayNumber)
                     && isNonEmptyString(request.resource.data.videoURL)
                     && request.resource.data.status is string
                     && request.resource.data.submittedAt is timestamp;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    //  craving_logs/{logId}  — Private craving logs
    //  Access: owner read/write
    // ═══════════════════════════════════════════════════════════════════

    match /craving_logs/{logId} {
      allow read:   if isAuthenticated()
                     && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
                     && request.auth.uid == request.resource.data.userId
                     && isNonEmptyString(request.resource.data.userId)
                     && isNonEmptyString(request.resource.data.copingMethod)
                     && request.resource.data.success is bool
                     && request.resource.data.timestamp is timestamp;
      allow update: if isAuthenticated()
                     && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated()
                     && request.auth.uid == resource.data.userId;
    }

    // ═══════════════════════════════════════════════════════════════════
    //  subscriptions/{userId}  — Subscription status
    //  Access: owner read; Cloud Functions write (admin SDK bypasses rules)
    // ═══════════════════════════════════════════════════════════════════

    match /subscriptions/{userId} {
      allow read:   if isOwner(userId);
      allow write:  if false;   // All writes via Cloud Functions only
    }

    // ═══════════════════════════════════════════════════════════════════
    //  coach_chats/{userId}/messages/{messageId}  — AI Coach conversations
    //  Access: owner read/write
    // ═══════════════════════════════════════════════════════════════════

    match /coach_chats/{userId} {
      allow read, write: if false;   // Parent doc not used directly

      match /messages/{messageId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId)
                       && isNonEmptyString(request.resource.data.content)
                       && request.resource.data.role is string
                       && request.resource.data.timestamp is timestamp;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Catch-all: deny everything else
    // ═══════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
